# 复制本文件为 .env 并填入你的 DeepSeek Key（.env 不会被提交到仓库）
# DeepSeek 控制台：https://platform.deepseek.com/

DEEPSEEK_API_KEY=sk-在这里填你的key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 博查 AI 搜索（Phase 2 主搜索源）
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com/v1
# 博查检索时间窗；留空=自动用目标日期（推荐）。如需覆盖可填 oneDay / oneWeek 等。
BOCHA_FRESHNESS=

# 备用 LLM 网关（可选）：主 DeepSeek 连续失败时自动降级。例：硅基流动 SiliconFlow
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=

# 时区（决定"昨天"是哪一天）
TIMEZONE=Asia/Shanghai

# 每个分类喂给模型的最大新闻条数（控制 token/成本）
MAX_ITEMS_PER_CATEGORY=25

# 抓取 RSS 的超时（秒）
HTTP_TIMEOUT=20

# 定时任务：每日几点生成 T-1 简报（0-23，分钟 0-59）；HOUR 设 -1 关闭定时。
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# API 跨域来源：默认 * ；上架前改成你的前端域名（逗号分隔）。
CORS_ORIGINS=*

# API 鉴权 Token（可选）：留空=不鉴权；填了则请求需带 Authorization: Bearer <token>
API_TOKEN=
